# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cpg_analytics
POSTGRES_USER=cpg_user
POSTGRES_PASSWORD=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Cube.js ───────────────────────────────────────────────────────────────────
CUBEJS_URL=http://cubejs:4000
CUBEJS_API_SECRET=change-me-cubejs-secret

# ── Anthropic (required for DSPy + RLHF) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-minimum-32-chars

# ── App ───────────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-haiku-4-5-20251001
DEBUG=false
